# 사이트 절대 URL — sitemap.xml · robots.txt · canonical · OG image base에 사용
# 우선순위: NEXT_PUBLIC_SITE_URL > VERCEL_PROJECT_PRODUCTION_URL (자동) > localhost
# 커스텀 도메인 연결 후에는 이 값을 명시적으로 설정 권장
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# 검색엔진 소유권 인증 (선택) — 발급받은 토큰만 넣으면 <meta> 태그 자동 노출
# Google Search Console > 설정 > 소유권 확인 > HTML 태그 → content 값
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# 네이버 서치어드바이저 > 사이트 등록 > 소유확인 > HTML 태그 → content 값
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
